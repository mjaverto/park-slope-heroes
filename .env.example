# Shopify LLM proxy token for image generation via tools/generate-sprites.js.
# Obtain a fresh personal token with:
#   /opt/dev/bin/devx llm-gateway print-token --key
#
# The sprite tool will automatically shell out to devx if this env var is
# unset or left as "replace-me", so most contributors can leave this blank.
SHOPIFY_PROXY_KEY=replace-me
